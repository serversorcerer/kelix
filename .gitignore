# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
.pytest_cache/
.ruff_cache/

# Kelix runtime state is local by default.
# Shareable memory/skills/backlog are explicitly re-included; run state,
# transcripts, and fleet coordination never leave the machine by default
# (they may contain command output). See docs/SECURITY.md.
.kelix/*
!.kelix/backlog.md
!.kelix/roadmap.md
!.kelix/STATE.md
!.kelix/phases/
!.kelix/memory/
.kelix/memory/*
!.kelix/memory/project.md
!.kelix/skills/
!.kelix/prompts/
!.kelix/kelix.toml

# OS
.DS_Store
